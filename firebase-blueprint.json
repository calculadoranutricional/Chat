{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A conversation between a user and Gemini",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages in a chat" }
  }
}
